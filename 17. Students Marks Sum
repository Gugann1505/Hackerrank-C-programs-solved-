#include <stdio.h>

int marks_summation(int* marks, int number_of_students, char gender) {
    int sum = 0;
    int start = (gender == 'b') ? 0 : 1;
    for (int i = start; i < number_of_students; i += 2) {
        sum += marks[i];
    }
    return sum;
}

int main() {
    int n; char g;
    scanf("%d", &n);
    int marks[n];
    for(int i=0; i<n; i++) scanf("%d", &marks[i]);
    scanf(" %c", &g);
    printf("%d", marks_summation(marks, n, g));
    return 0;
}
