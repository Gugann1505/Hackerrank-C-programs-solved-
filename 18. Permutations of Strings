#include <stdio.h>
#include <string.h>
#include <stdlib.h>

int next_permutation(int n, char **s) {
    int i = n - 2;
    while (i >= 0 && strcmp(s[i], s[i+1]) >= 0) i--;
    if (i < 0) return 0;
    int j = n - 1;
    while (strcmp(s[i], s[j]) >= 0) j--;
    char *tmp = s[i]; s[i] = s[j]; s[j] = tmp;
    int left = i + 1, right = n - 1;
    while (left < right) {
        tmp = s[left]; s[left] = s[right]; s[right] = tmp;
        left++; right--;
    }
    return 1;
}
